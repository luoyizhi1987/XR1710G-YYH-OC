From: XR1710G-YYH-OC Builder <builder@xr1710g.local>
Date: 2026-07-21
Subject: [PATCH] v2ray-geodata: update geoip/geosite to latest versions

The upstream feeds v2ray-geodata Makefile pins geoip to 202605120112
and geosite to 20260518025449, but both GitHub releases have been
removed (404). Update to the latest available versions:

  geoip:   202605120112 -> 202607171233 (sha256 b71d1999...)
  geosite: 20260518025449 -> 20260721085449 (sha256 4474555a...)

This is a version bump only — the package functionality (GeoIP database
and geosite list for v2ray/xray proxies) is fully preserved. The user
explicitly requested v2ray-geoip + v2ray-geosite in patch 004.
---
--- a/feeds/packages/net/v2ray-geodata/Makefile
+++ b/feeds/packages/net/v2ray-geodata/Makefile
@@ -9,16 +9,16 @@
 include $(INCLUDE_DIR)/package.mk

-GEOIP_VER:=202605120112
+GEOIP_VER:=202607171233
 GEOIP_FILE:=geoip.dat.$(GEOIP_VER)
 define Download/geoip
   URL:=https://github.com/v2fly/geoip/releases/download/$(GEOIP_VER)/
   URL_FILE:=geoip.dat
   FILE:=$(GEOIP_FILE)
-  HASH:=e9002979e0df72bce1c8751ff70725386594c551db684b7a232935b8b2bb8aa2
+  HASH:=b71d1999439dde2de2d2b6844a2befa50c50211ff739785c005ca7c230a17d6a
 endef

-GEOSITE_VER:=20260518025449
+GEOSITE_VER:=20260721085449
 GEOSITE_FILE:=dlc.dat.$(GEOSITE_VER)
 define Download/geosite
   URL:=https://github.com/v2fly/domain-list-community/releases/download/$(GEOSITE_VER)/
   URL_FILE:=dlc.dat
   FILE:=$(GEOSITE_FILE)
-  HASH:=330e9383df4b232747d900c70ff1718d396e0fff4914930285c24657e7f013a1
+  HASH:=4474555a11e03d86f7677a043ce717ac096e9f998a7d66e90fc7a1065ee0ab8a
 endef

 GEOSITE_IRAN_VER:=202603230100
