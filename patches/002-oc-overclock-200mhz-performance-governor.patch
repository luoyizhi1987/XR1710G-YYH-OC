From: XR1710G-YYH-OC Builder <builder@xr1710g.local>
Date: 2026-07-13
Subject: [PATCH] airoha: an7581 overclock +200 MHz

Port the overclocking behaviour from OpenWRT-fanboy/OpenW1700k
ubi2-oc branch. The DTS OPP table is shifted up by 200 MHz per step
(500-1200 MHz -> 700-1400 MHz). This raises the SoC's advertised
maximum CPU clock from 1.2 GHz to 1.4 GHz.
---
--- a/target/linux/airoha/dts/an7581.dtsi
+++ b/target/linux/airoha/dts/an7581.dtsi
@@ -171,78 +171,78 @@
 		compatible = "operating-points-v2";
 		opp-shared;
 
-		opp-500000000 {
-			opp-hz = /bits/ 64 <500000000>;
+		opp-700000000 {
+			opp-hz = /bits/ 64 <700000000>;
 			required-opps = <&smcc_opp0>;
 		};
 
-		opp-550000000 {
-			opp-hz = /bits/ 64 <550000000>;
+		opp-750000000 {
+			opp-hz = /bits/ 64 <750000000>;
 			required-opps = <&smcc_opp1>;
 		};
 
-		opp-600000000 {
-			opp-hz = /bits/ 64 <600000000>;
+		opp-800000000 {
+			opp-hz = /bits/ 64 <800000000>;
 			required-opps = <&smcc_opp2>;
 		};
 
-		opp-650000000 {
-			opp-hz = /bits/ 64 <650000000>;
+		opp-850000000 {
+			opp-hz = /bits/ 64 <850000000>;
 			required-opps = <&smcc_opp3>;
-		};
-
-		opp-7000000000 {
-			opp-hz = /bits/ 64 <700000000>;
-			required-opps = <&smcc_opp4>;
-		};
-
-		opp-7500000000 {
-			opp-hz = /bits/ 64 <750000000>;
-			required-opps = <&smcc_opp5>;
-		};
-
-		opp-8000000000 {
-			opp-hz = /bits/ 64 <800000000>;
-			required-opps = <&smcc_opp6>;
-		};
-
-		opp-8500000000 {
-			opp-hz = /bits/ 64 <850000000>;
-			required-opps = <&smcc_opp7>;
 		};
 
 		opp-9000000000 {
 			opp-hz = /bits/ 64 <900000000>;
-			required-opps = <&smcc_opp8>;
+			required-opps = <&smcc_opp4>;
 		};
 
 		opp-9500000000 {
 			opp-hz = /bits/ 64 <950000000>;
-			required-opps = <&smcc_opp9>;
+			required-opps = <&smcc_opp5>;
 		};
 
 		opp-10000000000 {
 			opp-hz = /bits/ 64 <1000000000>;
-			required-opps = <&smcc_opp10>;
+			required-opps = <&smcc_opp6>;
 		};
 
 		opp-10500000000 {
 			opp-hz = /bits/ 64 <1050000000>;
-			required-opps = <&smcc_opp11>;
+			required-opps = <&smcc_opp7>;
 		};
 
 		opp-11000000000 {
 			opp-hz = /bits/ 64 <1100000000>;
-			required-opps = <&smcc_opp12>;
+			required-opps = <&smcc_opp8>;
 		};
 
 		opp-11500000000 {
 			opp-hz = /bits/ 64 <1150000000>;
-			required-opps = <&smcc_opp13>;
+			required-opps = <&smcc_opp9>;
 		};
 
 		opp-12000000000 {
 			opp-hz = /bits/ 64 <1200000000>;
+			required-opps = <&smcc_opp10>;
+		};
+
+		opp-12500000000 {
+			opp-hz = /bits/ 64 <1250000000>;
+			required-opps = <&smcc_opp11>;
+		};
+
+		opp-13000000000 {
+			opp-hz = /bits/ 64 <1300000000>;
+			required-opps = <&smcc_opp12>;
+		};
+
+		opp-13500000000 {
+			opp-hz = /bits/ 64 <1350000000>;
+			required-opps = <&smcc_opp13>;
+		};
+
+		opp-14000000000 {
+			opp-hz = /bits/ 64 <1400000000>;
 			required-opps = <&smcc_opp14>;
 		};
 	};
-- 
